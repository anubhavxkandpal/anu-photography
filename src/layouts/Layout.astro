---
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Professional photography portfolio featuring landscapes, wildlife, portraits, travel, and artistic photography." } = Astro.props;

const galleryLinks = [
  { href: '/galleries/landscapes', label: 'Landscapes' },
  { href: '/galleries/wildlife', label: 'Wildlife' },
  { href: '/galleries/portraits', label: 'Portraits' },
  { href: '/galleries/travel', label: 'Travel' },
  { href: '/galleries/artsy', label: 'Artsy' },
  { href: '/galleries/events', label: 'Events' },
];

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/explore', label: 'Explore' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
const isGalleriesActive = pathname.startsWith('/galleries');
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Preload key fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    
    <!-- View Transitions for smooth page navigation -->
    <ViewTransitions />
  </head>
  <body class="bg-stone-950 text-gray-200 font-sans antialiased">
    <!-- Smooth Scroll Provider wraps everything -->
    <div id="smooth-scroll-wrapper">
      <div class="min-h-screen flex flex-col">
      <!-- Navigation -->
      <nav class="sticky top-0 z-50 bg-stone-950/90 backdrop-blur-sm border-b border-gray-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-center h-16">
            <!-- Logo/Brand -->
            <div class="flex-shrink-0">
              <a href="/" class="text-xl font-heading font-semibold text-gray-100 hover:text-white transition-colors">
                Anu Photography
              </a>
            </div>

            <!-- Navigation Links -->
            <div class="hidden lg:block">
              <div class="ml-10 flex items-center space-x-6">
                {navLinks.map((link) => (
                  link.href === '/explore' ? (
                    <a
                      href={link.href}
                      class="text-earth-400 hover:text-earth-300 px-2 py-2 text-sm font-semibold transition-colors"
                    >
                      {link.label}
                    </a>
                  ) : (
                    <a
                      href={link.href}
                      class:list={[
                        'px-2 py-2 text-sm font-medium transition-colors',
                        isActive(link.href) ? 'text-gray-100' : 'text-gray-400 hover:text-gray-100',
                      ]}
                    >
                      {link.label}
                    </a>
                  )
                ))}

                <!-- Galleries dropdown -->
                <div class="relative galleries-dropdown">
                  <button
                    type="button"
                    class:list={[
                      'galleries-trigger inline-flex items-center gap-1 px-2 py-2 text-sm font-medium transition-colors focus:outline-none',
                      isGalleriesActive ? 'text-gray-100' : 'text-gray-400 hover:text-gray-100',
                    ]}
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    Galleries
                    <svg class="galleries-chevron h-4 w-4 transition-transform duration-200" stroke="currentColor" fill="none" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </button>
                  <div class="galleries-panel hidden absolute right-0 mt-2 w-48 bg-stone-950 border border-gray-800 rounded-lg shadow-xl py-1">
                    {galleryLinks.map((link) => (
                      <a
                        href={link.href}
                        class:list={[
                          'block px-4 py-2 text-sm hover:bg-stone-900 transition-colors',
                          isActive(link.href) ? 'text-gray-100' : 'text-gray-400 hover:text-gray-100',
                        ]}
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- Mobile menu button -->
            <div class="lg:hidden">
              <button type="button" class="mobile-menu-button text-gray-400 hover:text-gray-100 focus:outline-none focus:text-gray-100" aria-label="Toggle menu">
                <svg class="h-6 w-6" stroke="currentColor" fill="none" viewBox="0 0 24 24">
                  <path class="inline" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Mobile Navigation Menu -->
        <div class="mobile-menu hidden lg:hidden">
          <div class="px-2 pt-2 pb-3 space-y-1 bg-stone-950 border-t border-gray-800">
            <a
              href="/"
              class:list={['block px-3 py-2 text-base font-medium', isActive('/') ? 'text-gray-100' : 'text-gray-400 hover:text-gray-100']}
            >Home</a>
            <a href="/explore" class="block text-earth-400 hover:text-earth-300 px-3 py-2 text-base font-semibold">Explore All</a>
            <div class="border-t border-gray-800 my-2"></div>
            {galleryLinks.map((link) => (
              <a
                href={link.href}
                class:list={['block px-3 py-2 text-base font-medium', isActive(link.href) ? 'text-gray-100' : 'text-gray-400 hover:text-gray-100']}
              >
                {link.label}
              </a>
            ))}
            <div class="border-t border-gray-800 my-2"></div>
            <a
              href="/about"
              class:list={['block px-3 py-2 text-base font-medium', isActive('/about') ? 'text-gray-100' : 'text-gray-400 hover:text-gray-100']}
            >About</a>
            <a
              href="/contact"
              class:list={['block px-3 py-2 text-base font-medium', isActive('/contact') ? 'text-gray-100' : 'text-gray-400 hover:text-gray-100']}
            >Contact</a>
          </div>
        </div>
      </nav>
      
      <!-- Main Content -->
      <main class="flex-1">
        <slot />
      </main>
      
      <!-- Footer -->
      <footer class="bg-stone-950 border-t border-gray-800 mt-auto">
        <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col md:flex-row justify-between items-center">
            <div class="text-gray-500 text-sm">
              © 2025 Anubhav Kandpal. All rights reserved.
            </div>
            <div class="flex space-x-6 mt-4 md:mt-0">
              <a href="/contact" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">
                Prints Available
              </a>
              <a href="/contact" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">
                Book a Session
              </a>
            </div>
          </div>
        </div>
      </footer>
      </div>
    </div>
    
    <script>
      import Lenis from '@studio-freight/lenis';

      let lenis: Lenis | null = null;

      // astro:page-load fires on initial load AND after every ViewTransitions
      // navigation; DOM listeners must be re-attached each time since the
      // <body> is swapped out.
      document.addEventListener('astro:page-load', () => {
        // Mobile menu toggle
        const mobileMenuButton = document.querySelector('.mobile-menu-button');
        const mobileMenu = document.querySelector('.mobile-menu');

        if (mobileMenuButton && mobileMenu) {
          mobileMenuButton.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
          });
          // Close the menu when a navigation link is chosen
          mobileMenu.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', () => mobileMenu.classList.add('hidden'));
          });
        }

        // Galleries dropdown
        const galleriesTrigger = document.querySelector<HTMLButtonElement>('.galleries-trigger');
        const galleriesPanel = document.querySelector<HTMLElement>('.galleries-panel');
        const galleriesChevron = document.querySelector<SVGElement>('.galleries-chevron');
        const galleriesWrapper = document.querySelector<HTMLElement>('.galleries-dropdown');

        if (galleriesTrigger && galleriesPanel && galleriesWrapper) {
          const closeDropdown = () => {
            galleriesPanel.classList.add('hidden');
            galleriesTrigger.setAttribute('aria-expanded', 'false');
            galleriesChevron?.classList.remove('rotate-180');
          };

          const openDropdown = () => {
            galleriesPanel.classList.remove('hidden');
            galleriesTrigger.setAttribute('aria-expanded', 'true');
            galleriesChevron?.classList.add('rotate-180');
          };

          galleriesTrigger.addEventListener('click', (event) => {
            event.stopPropagation();
            const isOpen = galleriesTrigger.getAttribute('aria-expanded') === 'true';
            if (isOpen) {
              closeDropdown();
            } else {
              openDropdown();
            }
          });

          document.addEventListener('click', (event) => {
            if (!galleriesWrapper.contains(event.target as Node)) {
              closeDropdown();
            }
          });

          document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
              closeDropdown();
            }
          });
        }

        // Smooth scrolling — Lenis runs on the window, so a single instance
        // survives ViewTransitions navigations.
        if (!lenis) {
          lenis = new Lenis({
            duration: 1.2,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            touchMultiplier: 2,
            wheelMultiplier: 1.5,
            infinite: false,
          });

          const raf = (time: number) => {
            lenis?.raf(time);
            requestAnimationFrame(raf);
          };
          requestAnimationFrame(raf);
        }
      });
    </script>
  </body>
</html>
