---
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Professional photography portfolio featuring landscapes, wildlife, portraits, travel, and artistic photography." } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Preload key fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    
    <!-- View Transitions for smooth page navigation -->
    <ViewTransitions />
  </head>
  <body class="bg-stone-950 text-gray-200 font-sans antialiased">
    <!-- Smooth Scroll Provider wraps everything -->
    <div id="smooth-scroll-wrapper">
      <div class="min-h-screen flex flex-col">
      <!-- Navigation -->
      <nav class="sticky top-0 z-50 bg-stone-950/90 backdrop-blur-sm border-b border-gray-800">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between items-center h-16">
            <!-- Logo/Brand -->
            <div class="flex-shrink-0">
              <a href="/" class="text-xl font-heading font-semibold text-gray-100 hover:text-white transition-colors">
                Anu Photography
              </a>
            </div>

            <!-- Navigation Links -->
            <div class="hidden lg:block">
              <div class="ml-10 flex items-baseline space-x-6">
                <a href="/" class="text-gray-400 hover:text-gray-100 px-2 py-2 text-sm font-medium transition-colors">
                  Home
                </a>
                <a href="/explore" class="text-earth-400 hover:text-earth-300 px-2 py-2 text-sm font-semibold transition-colors">
                  Explore
                </a>
                <a href="/galleries/landscapes" class="text-gray-400 hover:text-gray-100 px-2 py-2 text-sm font-medium transition-colors">
                  Landscapes
                </a>
                <a href="/galleries/wildlife" class="text-gray-400 hover:text-gray-100 px-2 py-2 text-sm font-medium transition-colors">
                  Wildlife
                </a>
                <a href="/galleries/portraits" class="text-gray-400 hover:text-gray-100 px-2 py-2 text-sm font-medium transition-colors">
                  Portraits
                </a>
                <a href="/galleries/travel" class="text-gray-400 hover:text-gray-100 px-2 py-2 text-sm font-medium transition-colors">
                  Travel
                </a>
                <a href="/galleries/artsy" class="text-gray-400 hover:text-gray-100 px-2 py-2 text-sm font-medium transition-colors">
                  Artsy
                </a>
                <a href="/about" class="text-gray-400 hover:text-gray-100 px-2 py-2 text-sm font-medium transition-colors">
                  About
                </a>
                <a href="/contact" class="text-gray-400 hover:text-gray-100 px-2 py-2 text-sm font-medium transition-colors">
                  Contact
                </a>
              </div>
            </div>

            <!-- Mobile menu button -->
            <div class="lg:hidden">
              <button type="button" class="mobile-menu-button text-gray-400 hover:text-gray-100 focus:outline-none focus:text-gray-100" aria-label="Toggle menu">
                <svg class="h-6 w-6" stroke="currentColor" fill="none" viewBox="0 0 24 24">
                  <path class="inline" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Mobile Navigation Menu -->
        <div class="mobile-menu hidden lg:hidden">
          <div class="px-2 pt-2 pb-3 space-y-1 bg-stone-950 border-t border-gray-800">
            <a href="/" class="block text-gray-400 hover:text-gray-100 px-3 py-2 text-base font-medium">Home</a>
            <a href="/explore" class="block text-earth-400 hover:text-earth-300 px-3 py-2 text-base font-semibold">Explore All</a>
            <div class="border-t border-gray-800 my-2"></div>
            <a href="/galleries/landscapes" class="block text-gray-400 hover:text-gray-100 px-3 py-2 text-base font-medium">Landscapes</a>
            <a href="/galleries/wildlife" class="block text-gray-400 hover:text-gray-100 px-3 py-2 text-base font-medium">Wildlife</a>
            <a href="/galleries/portraits" class="block text-gray-400 hover:text-gray-100 px-3 py-2 text-base font-medium">Portraits</a>
            <a href="/galleries/travel" class="block text-gray-400 hover:text-gray-100 px-3 py-2 text-base font-medium">Travel</a>
            <a href="/galleries/artsy" class="block text-gray-400 hover:text-gray-100 px-3 py-2 text-base font-medium">Artsy</a>
            <a href="/galleries/events" class="block text-gray-400 hover:text-gray-100 px-3 py-2 text-base font-medium">Events</a>
            <div class="border-t border-gray-800 my-2"></div>
            <a href="/about" class="block text-gray-400 hover:text-gray-100 px-3 py-2 text-base font-medium">About</a>
            <a href="/contact" class="block text-gray-400 hover:text-gray-100 px-3 py-2 text-base font-medium">Contact</a>
          </div>
        </div>
      </nav>
      
      <!-- Main Content -->
      <main class="flex-1">
        <slot />
      </main>
      
      <!-- Footer -->
      <footer class="bg-stone-950 border-t border-gray-800 mt-auto">
        <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col md:flex-row justify-between items-center">
            <div class="text-gray-500 text-sm">
              © 2025 Anubhav Kandpal. All rights reserved.
            </div>
            <div class="flex space-x-6 mt-4 md:mt-0">
              <a href="/contact" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">
                Prints Available
              </a>
              <a href="/contact" class="text-gray-500 hover:text-gray-200 text-sm transition-colors">
                Book a Session
              </a>
            </div>
          </div>
        </div>
      </footer>
      </div>
    </div>
    
    <script>
      import Lenis from '@studio-freight/lenis';

      let lenis: Lenis | null = null;

      // astro:page-load fires on initial load AND after every ViewTransitions
      // navigation; DOM listeners must be re-attached each time since the
      // <body> is swapped out.
      document.addEventListener('astro:page-load', () => {
        // Mobile menu toggle
        const mobileMenuButton = document.querySelector('.mobile-menu-button');
        const mobileMenu = document.querySelector('.mobile-menu');

        if (mobileMenuButton && mobileMenu) {
          mobileMenuButton.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
          });
          // Close the menu when a navigation link is chosen
          mobileMenu.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', () => mobileMenu.classList.add('hidden'));
          });
        }

        // Smooth scrolling — Lenis runs on the window, so a single instance
        // survives ViewTransitions navigations.
        if (!lenis) {
          lenis = new Lenis({
            duration: 1.2,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            touchMultiplier: 2,
            wheelMultiplier: 1.5,
            infinite: false,
          });

          const raf = (time: number) => {
            lenis?.raf(time);
            requestAnimationFrame(raf);
          };
          requestAnimationFrame(raf);
        }
      });
    </script>
  </body>
</html>
