# Anthropic API Key for auto-tagging feature
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# Netlify personal access token (for Netlify MCP / CLI access)
# Create one at: https://app.netlify.com/user/applications
NETLIFY_AUTH_TOKEN=your-netlify-token-here
